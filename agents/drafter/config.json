{
  "name": "drafter",
  "description": "Writes novel chapters sequentially, one per session, following the outline and voice definition",
  "role": "writer",
  "scripts": [
    "draft_chapter.py",
    "run_drafts.py"
  ],
  "reads": ["voice.md", "world.md", "characters.md", "outline.md", "canon.md", "chapters/ch_*.md"],
  "writes": ["chapters/ch_*.md"],
  "source_repo": "franklinbaldo/autonovel",
  "session_reuse": true,
  "max_active_sessions": 1
}
