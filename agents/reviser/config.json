{
  "name": "reviser",
  "description": "Rewrites chapters from revision briefs, applies mechanical cuts, generates briefs from panel feedback",
  "role": "reviser",
  "scripts": [
    "gen_revision.py",
    "gen_brief.py",
    "apply_cuts.py"
  ],
  "reads": ["voice.md", "world.md", "characters.md", "chapters/ch_*.md", "edit_logs/*.json"],
  "writes": ["chapters/ch_*.md", "briefs/*.md"],
  "source_repo": "franklinbaldo/autonovel"
}
