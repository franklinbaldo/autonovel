# ── Cognitive Motor ──────────────────────────────────────────────
# Choose ONE: "jules" (Google Jules Sequence) or "anthropic" (direct Claude API)
AUTONOVEL_ENGINE=jules

# ── Jules Sequence Configuration (when AUTONOVEL_ENGINE=jules) ──
# Google Cloud API key with Jules API access
JULES_API_KEY=your-jules-api-key-here

# Jules API base URL
JULES_API_BASE_URL=https://jules.googleapis.com/v1alpha

# Source repository for Jules sessions (owner/repo format)
JULES_SOURCE_REPO=your-org/autonovel

# Polling interval in seconds (how often to check session status)
JULES_POLL_INTERVAL=3

# Maximum wait time in seconds for a single session to complete
JULES_MAX_WAIT=900

# ── Anthropic Configuration (when AUTONOVEL_ENGINE=anthropic) ───
# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Writer model (used for drafting and revision)
AUTONOVEL_WRITER_MODEL=claude-sonnet-4-6

# Judge model (used for evaluation — should differ from writer)
AUTONOVEL_JUDGE_MODEL=claude-sonnet-4-6

# Review model (Opus — deep prose-level analysis, used in Phase 3b)
AUTONOVEL_REVIEW_MODEL=claude-opus-4-6

# API base URL
AUTONOVEL_API_BASE_URL=https://api.anthropic.com

# ── External Services (used by both engines) ────────────────────
# fal.ai key for image generation (Nano Banana 2)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
